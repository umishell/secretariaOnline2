// ============================================================
// M3 — Solicitações / Workflow Engine (5 tabelas)
// Fonte: §5.3 analise_arquitetural + MVP v2 §4
//        + workflow-engine-specialist.md
// Decisões aplicadas: I11 + §0.3.1 (nomes §5.3; status em attachment)
//   - numero_anual + ano (não numero string)
//   - estado_anterior / estado_novo / parecer / tipo / at  (não de_estado etc.)
//   - request_line_item MANTIDA (ausente no v2 mas presente no TCC)
//   - request_attachment + status PENDING/CONFIRMED (I11-a)
//   - form_schema e workflow_json são JSONB em request_type (não tabelas — I3)
// ============================================================

Table request_type {
  id           uuid        [pk, not null]
  code         varchar(50) [unique, not null, note: 'ADIANTAMENTO_PERIODO, APROVEITAMENTO_DISCIPLINA... (19 tipos)']
  descricao    varchar(200) [not null]
  prazo_dias   integer     [not null, default: 15]
  interna      boolean     [not null, default: false, note: 'true = uso interno secretaria']
  form_schema  jsonb       [not null, note: 'JSON Schema Draft-07 — campos do formulário dinâmico']
  workflow_json jsonb      [not null, note: 'state machine: { initial, states[], transitions[] }']
  required_auth jsonb      [not null, default: `'[]'`, note: 'authorities[] que podem deliberar']
  ativo        boolean     [not null, default: true]
}

Table request {
  id              uuid        [pk, not null]
  numero_anual    integer     [not null, note: 'sequência reiniciada por ano']
  ano             smallint    [not null]
  id_solicitante  uuid        [not null, ref: > usuario.id, note: 'FK cross-módulo → M1 IAM']
  id_request_type uuid        [not null, ref: > request_type.id]
  id_curso        uuid        [not null, ref: > curso.id, note: 'FK cross-módulo → M2 Acadêmico']
  estado          varchar(50) [not null, note: 'controlado pelo WorkflowEngine: RASCUNHO, ABERTA, EM_TRIAGEM, EM_DELIBERACAO, EM_AJUSTE, DEFERIDA, INDEFERIDA, EM_REVISAO, ARQUIVADA']
  dados           jsonb       [not null, default: `'{}'`, note: 'payload do form_schema preenchido pelo solicitante']
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]
  concluded_at    timestamptz [note: 'preenchido quando estado terminal (DEFERIDA, INDEFERIDA, ARQUIVADA)']
  prazo_em        timestamptz [not null, note: 'created_at + prazo_dias do request_type']

  Indexes {
    (ano, numero_anual) [unique, note: 'protocolo único por ano']
  }
}

// Histórico imutável de transições (append-only — workflow-engine-specialist.md)
Table request_event {
  id              uuid        [pk, not null]
  id_request      uuid        [not null, ref: > request.id, note: 'CASCADE — evento órfão impossível']
  id_ator         uuid        [ref: > usuario.id, note: 'FK cross-módulo → M1 IAM; nullable = sistema']
  tipo            varchar(50) [not null, note: 'OPENED, ASSIGNED, FORWARDED, DEFERRED, DENIED, REQUEST_ADJUSTMENT, RESUBMIT, REQUEST_REVIEW, ARCHIVED']
  estado_anterior varchar(50) [note: 'null no primeiro evento (OPENED)']
  estado_novo     varchar(50) [note: 'estado após a transição']
  parecer         text        [note: 'justificativa do deliberador']
  metadata        jsonb       [not null, default: `'{}'`, note: 'dados extras da transição (ex: notifyTemplate usado)']
  at              timestamptz [not null, default: `now()`]
}

// Linhas por disciplina — usado em APROVEITAMENTO_DISCIPLINA, INCLUSAO, EXCLUSAO etc.
Table request_line_item {
  id            uuid        [pk, not null]
  id_request    uuid        [not null, ref: > request.id, note: 'CASCADE']
  id_disciplina uuid        [ref: > disciplina.id, note: 'FK cross-módulo → M2 Acadêmico; nullable']
  operacao      varchar(20) [note: 'INCLUSAO | EXCLUSAO | APROVEITAMENTO']
  turma         varchar(10)
  estado        varchar(30) [not null, default: 'PENDENTE']
  parecer       text
  metadata      jsonb       [not null, default: `'{}'`]
}

// Decisão I11-a — status adicionado do MVP v2 §4 (PENDING/CONFIRMED)
Table request_attachment {
  id            uuid         [pk, not null]
  id_request    uuid         [not null, ref: > request.id, note: 'CASCADE']
  categoria     varchar(50)  [not null, note: 'EMENTA, HISTORICO, CONTRATO, ATESTADO_MEDICO...']
  nome_original varchar(255) [not null]
  storage_key   varchar(500) [not null, note: 'chave no MinIO/S3']
  mime_type     varchar(100) [not null]
  tamanho_bytes bigint       [not null]
  sha256        char(64)     [not null, note: 'integridade — calculado no cliente antes do upload']
  uploaded_by   uuid         [not null, ref: > usuario.id, note: 'FK cross-módulo → M1 IAM']
  status        varchar(20)  [not null, default: 'CONFIRMED', note: 'PENDING (URL gerada) | CONFIRMED (upload concluído) — I11-a']
  uploaded_at   timestamptz  [not null, default: `now()`]
}

// ============================================================
// FKs cross-módulo originadas neste módulo M3
// ============================================================
// request.id_solicitante        →  usuario.id        (M1 IAM)
// request.id_curso              →  curso.id          (M2 Acadêmico)
// request_event.id_ator         →  usuario.id        (M1 IAM)
// request_line_item.id_disciplina → disciplina.id    (M2 Acadêmico)
// request_attachment.uploaded_by → usuario.id        (M1 IAM)
// ============================================================
// FKs cross-módulo recebidas (outros módulos apontam para M3)
// ============================================================
// M2  calendario_academico.id_request_type → request_type.id
// ============================================================
