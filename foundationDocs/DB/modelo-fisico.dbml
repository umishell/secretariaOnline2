// =============================================================================
// FIGURA 4 — Modelo físico do banco de dados transacional — SecretariaOnline2
// FONTE: Os autores (2026).
// Gerado: Etapa 4 — derivado de foundationDocs/DB/modelo-logico.dbml
// Tabelas: 31 (29 domínio + refresh_token + jti_blacklist)
// Observação: nenhuma tabela do modelo lógico foi removida.
// =============================================================================

Project secretariaonline2_fisico {
  database_type: "PostgreSQL"
  Note: "PostgreSQL 16 · UUIDv7 · JSONB · CITEXT · índices de filtros/UI + GIN + parciais documentados"
}

// =============================================================================
// M1 — IAM + Sessão
// =============================================================================

Table usuario [note: "CHECKs implícitos de domínio via aplicação; soft delete em deleted_at"] {
  id                  uuid          [pk, not null, default: `uuid_generate_v7()`]
  nome                varchar(200)  [not null]
  cpf                 varchar(11)   [unique]
  email               citext        [unique, not null]
  email_ufpr          citext        [unique]
  grr                 varchar(20)   [unique]
  senha_hash          varchar(200)  [not null, note: "Argon2id"]
  senha_alterada      boolean       [not null, default: false]
  telefone            varchar(30)
  id_curso            uuid          [ref: > curso.id]
  metadata            jsonb         [not null, default: `'{}'::jsonb`]
  password_history    jsonb         [not null, default: `'[]'::jsonb`, note: "últimos hashes para política de reutilização"]
  falhas_consecutivas integer       [not null, default: 0]
  bloqueado_ate       timestamptz
  ativo               boolean       [not null, default: true]
  created_at          timestamptz   [not null, default: `now()`]
  updated_at          timestamptz   [not null, default: `now()`]
  deleted_at          timestamptz

  Indexes {
    email [name: "idx_usuario_email", unique]
    grr [name: "idx_usuario_grr", unique]
    id_curso [name: "idx_usuario_curso", note: "partial WHERE deleted_at IS NULL"]
    nome [name: "idx_usuario_nome_trgm", type: gin, note: "gin_trgm_ops (trigrama)"]
  }
}

Table role {
  id          uuid          [pk, not null, default: `uuid_generate_v7()`]
  code        varchar(50)   [unique, not null]
  description varchar(200)  [not null]
}

Table authority {
  id          uuid           [pk, not null, default: `uuid_generate_v7()`]
  code        varchar(100)   [unique, not null]
  description varchar(200)   [not null]
}

Table role_authority {
  id_role      uuid [not null, ref: > role.id]
  id_authority uuid [not null, ref: > authority.id]

  Indexes {
    (id_role, id_authority) [pk]
    id_role [name: "idx_role_authority_role"]
    id_authority [name: "idx_role_authority_authority"]
  }
}

Table usuario_role {
  id_usuario uuid   [not null, ref: > usuario.id, note: "ON DELETE CASCADE"]
  id_role    uuid   [not null, ref: > role.id, note: "ON DELETE CASCADE"]
  escopo     jsonb  [not null, default: `'{}'::jsonb`]

  Indexes {
    (id_usuario, id_role) [pk]
    id_role [name: "idx_usuario_role_role"]
  }
}

Table refresh_token [note: "Tabela técnica IAM (I5). Sem password_reset_token; reset usa JWT 1-uso + jti_blacklist (I6)."] {
  id          uuid         [pk, not null, default: `uuid_generate_v7()`]
  id_usuario  uuid         [not null, ref: > usuario.id, note: "ON DELETE CASCADE (composição)"]
  token_hash  varchar(200) [not null]
  expira_em   timestamptz  [not null]
  usado_em    timestamptz
  revogado_em timestamptz
  ip          inet
  user_agent  text
  created_at  timestamptz  [not null, default: `now()`]

  Indexes {
    id_usuario [name: "idx_refresh_token_usuario"]
    expira_em [name: "idx_refresh_token_expira_em"]
    revogado_em [name: "idx_refresh_token_revogado_em"]
  }
}

Table jti_blacklist [note: "Tabela técnica IAM (I6). PK natural = jti."] {
  jti        uuid         [pk, not null]
  expira_em  timestamptz  [not null]
  created_at timestamptz  [not null, default: `now()`]

  Indexes {
    expira_em [name: "idx_jti_blacklist_expira_em"]
  }
}

// =============================================================================
// M2 — Acadêmico
// =============================================================================

Table curso [note: "I7: circularidade com usuario resolvida por FK tardia em id_coordenador"] {
  id                   uuid         [pk, not null, default: `uuid_generate_v7()`]
  nome                 varchar(200) [not null]
  sigla                varchar(20)  [unique, not null]
  codigo_sie           varchar(20)
  id_coordenador       uuid         [ref: > usuario.id]
  tipo_calendario      smallint     [not null, note: "15 ou 18 semanas"]
  horas_formativas_req integer      [not null, default: 0]
  ativo                boolean      [not null, default: true]
  created_at           timestamptz  [not null, default: `now()`]

  Indexes {
    sigla [name: "idx_curso_sigla", unique]
    id_coordenador [name: "idx_curso_coordenador"]
  }
}

Table disciplina {
  id            uuid         [pk, not null, default: `uuid_generate_v7()`]
  codigo        varchar(30)  [not null]
  nome          varchar(200) [not null]
  id_curso      uuid         [not null, ref: > curso.id]
  periodo       smallint
  carga_horaria integer
  ativa         boolean      [not null, default: true]

  Indexes {
    (id_curso, codigo) [name: "uk_disciplina_curso_codigo", unique]
    id_curso [name: "idx_disciplina_curso"]
  }
}

Table periodo_letivo [note: "CHECK: semestre IN (1,2)"] {
  id       uuid      [pk, not null, default: `uuid_generate_v7()`]
  ano      smallint  [not null]
  semestre smallint  [not null]
  data_ini date      [not null]
  data_fim date      [not null]

  Indexes {
    (ano, semestre) [name: "uk_periodo_letivo_ano_semestre", unique]
  }
}

Table calendario_academico [note: "CHECK: dt_fim >= dt_ini"] {
  id              uuid  [pk, not null, default: `uuid_generate_v7()`]
  id_periodo      uuid  [not null, ref: > periodo_letivo.id]
  id_request_type uuid  [not null, ref: > request_type.id]
  dt_ini          date  [not null]
  dt_fim          date  [not null]
  observacao      text

  Indexes {
    id_periodo [name: "idx_calendario_periodo"]
    id_request_type [name: "idx_calendario_request_type"]
    (id_periodo, id_request_type) [name: "idx_calendario_periodo_tipo"]
  }
}

// =============================================================================
// M3 — Solicitações / Workflow Engine
// =============================================================================

Table request_type [note: "I3: form_schema + workflow_json como JSONB, sem tabelas auxiliares"] {
  id            uuid         [pk, not null, default: `uuid_generate_v7()`]
  code          varchar(50)  [unique, not null]
  descricao     varchar(200) [not null]
  prazo_dias    integer      [not null, default: 15]
  interna       boolean      [not null, default: false]
  form_schema   jsonb        [not null]
  workflow_json jsonb        [not null]
  required_auth jsonb        [not null, default: `'[]'::jsonb`]
  ativo         boolean      [not null, default: true]

  Indexes {
    code [name: "idx_request_type_code", unique]
    ativo [name: "idx_request_type_ativo"]
    form_schema [name: "idx_request_type_form_schema_gin", type: gin]
    workflow_json [name: "idx_request_type_workflow_json_gin", type: gin]
  }
}

Table request {
  id              uuid         [pk, not null, default: `uuid_generate_v7()`]
  numero_anual    integer      [not null]
  ano             smallint     [not null]
  id_solicitante  uuid         [not null, ref: > usuario.id]
  id_request_type uuid         [not null, ref: > request_type.id]
  id_curso        uuid         [not null, ref: > curso.id]
  estado          varchar(50)  [not null]
  dados           jsonb        [not null, default: `'{}'::jsonb`]
  created_at      timestamptz  [not null, default: `now()`]
  updated_at      timestamptz  [not null, default: `now()`]
  concluded_at    timestamptz
  prazo_em        timestamptz  [not null]

  Indexes {
    (ano, numero_anual) [name: "uk_request_ano_numero_anual", unique]
    id_solicitante [name: "idx_request_solicitante"]
    id_request_type [name: "idx_request_tipo"]
    id_curso [name: "idx_request_curso"]
    estado [name: "idx_request_estado"]
    (id_curso, estado) [name: "idx_request_curso_estado"]
    prazo_em [name: "idx_request_prazo_abertas", note: "partial WHERE concluded_at IS NULL"]
    dados [name: "idx_request_dados_gin", type: gin]
  }
}

Table request_event {
  id              uuid         [pk, not null, default: `uuid_generate_v7()`]
  id_request      uuid         [not null, ref: > request.id, note: "ON DELETE CASCADE (composição)"]
  id_ator         uuid         [ref: > usuario.id]
  tipo            varchar(50)  [not null]
  estado_anterior varchar(50)
  estado_novo     varchar(50)
  parecer         text
  metadata        jsonb        [not null, default: `'{}'::jsonb`]
  at              timestamptz  [not null, default: `now()`]

  Indexes {
    id_ator [name: "idx_request_event_ator"]
    (id_request, at) [name: "idx_request_event_req_at_desc", note: "desc em SQL físico"]
  }
}

Table request_line_item {
  id            uuid         [pk, not null, default: `uuid_generate_v7()`]
  id_request    uuid         [not null, ref: > request.id, note: "ON DELETE CASCADE (composição)"]
  id_disciplina uuid         [ref: > disciplina.id]
  operacao      varchar(20)
  turma         varchar(10)
  estado        varchar(30)  [not null, default: "PENDENTE"]
  parecer       text
  metadata      jsonb        [not null, default: `'{}'::jsonb`]

  Indexes {
    id_request [name: "idx_request_line_item_request"]
    id_disciplina [name: "idx_request_line_item_disciplina"]
    estado [name: "idx_request_line_item_estado"]
  }
}

Table request_attachment [note: "I11 confirmado: status PENDING/CONFIRMED"] {
  id            uuid          [pk, not null, default: `uuid_generate_v7()`]
  id_request    uuid          [not null, ref: > request.id, note: "ON DELETE CASCADE (composição)"]
  categoria     varchar(50)   [not null]
  nome_original varchar(255)  [not null]
  storage_key   varchar(500)  [not null]
  mime_type     varchar(100)  [not null]
  tamanho_bytes bigint        [not null]
  sha256        char(64)      [not null]
  uploaded_by   uuid          [not null, ref: > usuario.id]
  status        varchar(20)   [not null, default: "CONFIRMED", note: "CHECK recomendado: status IN ('PENDING','CONFIRMED')"]
  uploaded_at   timestamptz   [not null, default: `now()`]

  Indexes {
    id_request [name: "idx_request_attachment_request"]
    uploaded_by [name: "idx_request_attachment_uploaded_by"]
    status [name: "idx_request_attachment_status"]
    sha256 [name: "idx_request_attachment_sha256"]
  }
}

// =============================================================================
// M4 — Formativas
// =============================================================================

Table formative_activity {
  id                uuid          [pk, not null, default: `uuid_generate_v7()`]
  id_curso          uuid          [not null, ref: > curso.id]
  descricao         varchar(300)  [not null]
  qtd_horas_max     integer       [not null]
  doc_comprobatorio varchar(300)
  ativa             boolean       [not null, default: true]

  Indexes {
    id_curso [name: "idx_formative_activity_curso"]
    ativa [name: "idx_formative_activity_ativa"]
  }
}

Table formative_entry {
  id               uuid         [pk, not null, default: `uuid_generate_v7()`]
  id_aluno         uuid         [not null, ref: > usuario.id]
  id_activity      uuid         [not null, ref: > formative_activity.id]
  horas_declaradas integer      [not null]
  horas_validadas  integer
  estado           varchar(30)  [not null, default: "SUBMETIDA"]
  parecer          text
  id_storage_key   uuid
  created_at       timestamptz  [not null, default: `now()`]
  reviewed_at      timestamptz
  reviewed_by      uuid         [ref: > usuario.id]

  Indexes {
    id_aluno [name: "idx_formative_entry_aluno"]
    id_activity [name: "idx_formative_entry_activity"]
    reviewed_by [name: "idx_formative_entry_reviewed_by"]
    estado [name: "idx_formative_entry_estado"]
  }
}

// =============================================================================
// M5 — Estágio
// =============================================================================

Table internship {
  id                uuid          [pk, not null, default: `uuid_generate_v7()`]
  id_aluno          uuid          [not null, ref: > usuario.id]
  id_orientador     uuid          [not null, ref: > usuario.id]
  id_coe            uuid          [ref: > usuario.id]
  empresa_nome      varchar(200)  [not null]
  supervisor_nome   varchar(200)
  supervisor_email  citext
  supervisor_tel    varchar(30)
  data_ini          date          [not null]
  data_fim_prevista date
  data_fim          date
  ch_semanal        integer
  valor_bolsa_cents integer
  obrigatorio       boolean       [not null]
  num_contrato      varchar(50)
  num_processo_sei  varchar(50)
  estado            varchar(30)   [not null]
  created_at        timestamptz   [not null, default: `now()`]

  Indexes {
    id_aluno [name: "idx_internship_aluno"]
    id_orientador [name: "idx_internship_orientador"]
    id_coe [name: "idx_internship_coe"]
    estado [name: "idx_internship_estado"]
    data_ini [name: "idx_internship_data_ini"]
  }
}

Table internship_document {
  id            uuid         [pk, not null, default: `uuid_generate_v7()`]
  id_internship uuid         [not null, ref: > internship.id, note: "ON DELETE CASCADE (composição)"]
  categoria     varchar(50)  [not null]
  storage_key   varchar(500) [not null]
  sha256        char(64)     [not null]
  emitido_em    date

  Indexes {
    id_internship [name: "idx_internship_document_internship"]
    categoria [name: "idx_internship_document_categoria"]
    sha256 [name: "idx_internship_document_sha256"]
  }
}

// =============================================================================
// M6 — TCC
// =============================================================================

Table tcc {
  id          uuid          [pk, not null, default: `uuid_generate_v7()`]
  id_curso    uuid          [not null, ref: > curso.id]
  tema        varchar(300)  [not null]
  data_defesa timestamptz
  id_sala     uuid
  link_artigo varchar(500)
  storage_key varchar(500)
  estado      varchar(30)   [not null]

  Indexes {
    id_curso [name: "idx_tcc_curso"]
    estado [name: "idx_tcc_estado"]
    data_defesa [name: "idx_tcc_data_defesa"]
  }
}

Table tcc_member {
  id_tcc   uuid [not null, ref: > tcc.id, note: "ON DELETE CASCADE (composição)"]
  id_aluno uuid [not null, ref: > usuario.id]

  Indexes {
    (id_tcc, id_aluno) [pk]
    id_aluno [name: "idx_tcc_member_aluno"]
  }
}

Table tcc_examiner {
  id_tcc       uuid    [not null, ref: > tcc.id, note: "ON DELETE CASCADE (composição)"]
  id_professor uuid    [not null, ref: > usuario.id]
  orientador   boolean [not null]

  Indexes {
    (id_tcc, id_professor) [pk]
    id_professor [name: "idx_tcc_examiner_professor"]
  }
}

// =============================================================================
// M7 — Comunicação + Outbox
// =============================================================================

Table communication {
  id            uuid          [pk, not null, default: `uuid_generate_v7()`]
  tipo          varchar(30)   [not null]
  prioridade    smallint      [not null]
  titulo        varchar(200)  [not null]
  corpo_md      text          [not null]
  id_curso_alvo uuid          [ref: > curso.id]
  audiencia     jsonb         [not null, default: `'{}'::jsonb`]
  publicado_em  timestamptz   [not null, default: `now()`]
  expira_em     timestamptz
  id_autor      uuid          [not null, ref: > usuario.id]

  Indexes {
    id_curso_alvo [name: "idx_communication_curso_alvo"]
    id_autor [name: "idx_communication_autor"]
    publicado_em [name: "idx_communication_publicado_em"]
    expira_em [name: "idx_communication_expira_em"]
    audiencia [name: "idx_communication_audiencia_gin", type: gin]
  }
}

Table communication_delivery {
  id              uuid         [pk, not null, default: `uuid_generate_v7()`]
  id_comm         uuid         [not null, ref: > communication.id, note: "ON DELETE CASCADE (composição)"]
  id_destinatario uuid         [not null, ref: > usuario.id]
  canal           varchar(20)  [not null]
  estado          varchar(20)  [not null]
  tentativas      smallint     [not null, default: 0]
  last_error      text
  sent_at         timestamptz
  read_at         timestamptz

  Indexes {
    id_comm [name: "idx_communication_delivery_comm"]
    id_destinatario [name: "idx_communication_delivery_destinatario"]
    estado [name: "idx_communication_delivery_estado"]
    (id_destinatario, estado) [name: "idx_communication_delivery_dest_estado"]
  }
}

Table notification_preference {
  id_usuario uuid  [pk, not null, ref: > usuario.id, note: "ON DELETE CASCADE (composição)"]
  email_on   jsonb [not null, default: `'{"critical":true,"high":true}'::jsonb`]
  push_on    jsonb [not null, default: `'{"critical":true,"high":true,"medium":true}'::jsonb`]
  dnd_from   time
  dnd_to     time
}

Table outbox_event [note: "CHECK recomendado: status IN ('PENDING','SENT','FAILED','DEAD')"] {
  id              uuid          [pk, not null, default: `uuid_generate_v7()`]
  aggregate_type  varchar(50)   [not null]
  aggregate_id    uuid          [not null]
  event_type      varchar(100)  [not null]
  payload         jsonb         [not null]
  status          varchar(20)   [not null, default: "PENDING"]
  tentativas      smallint      [not null, default: 0]
  next_attempt_at timestamptz   [not null, default: `now()`]
  created_at      timestamptz   [not null, default: `now()`]
  processed_at    timestamptz

  Indexes {
    (aggregate_type, aggregate_id) [name: "idx_outbox_aggregate"]
    event_type [name: "idx_outbox_event_type"]
    status [name: "idx_outbox_status"]
    next_attempt_at [name: "idx_outbox_pending", note: "partial WHERE status = 'PENDING'"]
    payload [name: "idx_outbox_payload_gin", type: gin]
  }
}

// =============================================================================
// M8 — Presença v4.1
// =============================================================================

Table event_attendance [note: "CHECKs recomendados: attendance_mode ENUM lógico; estado IN ('AGENDADO','EM_ANDAMENTO','CONCLUIDO')"] {
  id                 uuid          [pk, not null, default: `uuid_generate_v7()`]
  titulo             varchar(200)  [not null]
  id_curso           uuid          [ref: > curso.id]
  organizador        uuid          [not null, ref: > usuario.id]
  ini_em             timestamptz   [not null]
  fim_em             timestamptz   [not null]
  ch_creditadas      numeric(5,2)  [not null]
  attendance_mode    varchar(30)   [not null]
  validation_windows jsonb
  estado             varchar(30)   [not null, default: "AGENDADO"]
  pin_entrada_hash   varchar(128)
  pin_saida_hash     varchar(128)
  janela_entrada_ini timestamptz
  janela_entrada_fim timestamptz
  janela_saida_ini   timestamptz
  janela_saida_fim   timestamptz

  Indexes {
    id_curso [name: "idx_event_attendance_curso"]
    organizador [name: "idx_event_attendance_organizador"]
    estado [name: "idx_event_attendance_estado"]
    attendance_mode [name: "idx_event_attendance_mode"]
    (ini_em, fim_em) [name: "idx_event_attendance_janela"]
    validation_windows [name: "idx_event_attendance_windows_gin", type: gin]
  }
}

Table attendance_session {
  id          uuid         [pk, not null, default: `uuid_generate_v7()`]
  id_evento   uuid         [not null, ref: > event_attendance.id, note: "ON DELETE CASCADE (composição)"]
  id_aluno    uuid         [not null, ref: > usuario.id]
  device_uuid uuid         [not null]
  entrada_em  timestamptz
  saida_em    timestamptz
  estado      varchar(40)  [not null]
  created_at  timestamptz  [not null, default: `now()`]

  Indexes {
    (id_evento, id_aluno) [name: "uk_attendance_session_evento_aluno", unique]
    (id_evento, device_uuid) [name: "uk_attendance_session_evento_device", unique]
    id_aluno [name: "idx_attendance_session_aluno"]
    estado [name: "idx_attendance_session_estado"]
  }
}

// =============================================================================
// M9 — Certificado + Auditoria
// =============================================================================

Table certificate {
  id              uuid          [pk, not null, default: `uuid_generate_v7()`]
  id_beneficiario uuid          [not null, ref: > usuario.id]
  id_evento       uuid          [ref: > event_attendance.id]
  id_formativa    uuid          [ref: > formative_entry.id]
  titulo          varchar(200)  [not null]
  ch_horas        numeric(5,2)  [not null]
  emitido_em      timestamptz   [not null, default: `now()`]
  emitente_nome   varchar(200)  [not null]
  hash_sha256     char(64)      [unique, not null]
  signature_alg   varchar(30)   [not null]
  signature_b64   text          [not null]
  verifier_url    varchar(300)  [not null]
  storage_key     varchar(500)  [not null]

  Indexes {
    hash_sha256 [name: "idx_cert_hash", unique]
    id_beneficiario [name: "idx_certificate_beneficiario"]
    id_evento [name: "idx_certificate_evento"]
    id_formativa [name: "idx_certificate_formativa"]
    emitido_em [name: "idx_certificate_emitido_em"]
  }
}

Table audit_log [note: "CHECK recomendado: resultado IN ('OK','DENIED','ERROR')"] {
  id         uuid          [pk, not null, default: `uuid_generate_v7()`]
  at         timestamptz   [not null, default: `now()`]
  id_ator    uuid          [ref: > usuario.id]
  acao       varchar(100)  [not null]
  alvo_tipo  varchar(50)   [not null]
  alvo_id    uuid
  ip         inet
  user_agent text
  payload    jsonb         [default: `'{}'::jsonb`]
  resultado  varchar(20)   [not null]

  Indexes {
    id_ator [name: "idx_audit_ator"]
    (id_ator, at) [name: "idx_audit_ator_at_desc", note: "desc em SQL físico"]
    (alvo_tipo, alvo_id) [name: "idx_audit_alvo"]
    at [name: "idx_audit_at"]
    payload [name: "idx_audit_payload_gin", type: gin]
  }
}

