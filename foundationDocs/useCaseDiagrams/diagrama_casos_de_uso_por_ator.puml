' =============================================================================
' SecretariaOnline2 — casos de uso POR ATOR (legibilidade)
' Prefixo de id dos diagramas: ucs_ (use case split por ator) — nomes de ficheiro exportados.
' Um @startuml por ator: uma unica origem de setas, sem sobreposicao entre perfis.
' Fonte das ligacoes: diagrama_casos_de_uso_secretariaonline2.puml (pagina 1) / casos_de_uso.md
'
' Exportar: npx plantuml-cli -tsvg -o svg diagrama_casos_de_uso_por_ator.puml
' Visao global (todos os atores no mesmo desenho): diagrama_casos_de_uso_secretariaonline2.puml
' =============================================================================


@startuml ucs_A1_visitante
title UC por ator - A1 Visitante (pre-login)
skinparam defaultFontName Helvetica
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundcorner 8
skinparam actorStyle awesome
skinparam ArrowThickness 1.5
left to right direction
actor "A1\nVisitante" as A1
package "Casos de uso" {
  usecase "UC-PUB-01\nPagina institucional / erro" as UC_PUB01
  usecase "UC-AUT-01\nAutenticar-se" as UC_A01
  usecase "UC-AUT-02\nRecuperar senha" as UC_A02
  usecase "UC-AUT-03\nRedefinir senha" as UC_A03
  usecase "UC-CRT-02\nVerificar protocolo" as UC_X02
  usecase "UC-CRT-03\nVerificar certificado" as UC_X03
}
A1 --> UC_PUB01
A1 --> UC_A01
A1 --> UC_A02
A1 --> UC_A03
A1 --> UC_X02
A1 --> UC_X03
note bottom
  Diagrama global: diagrama_casos_de_uso_secretariaonline2_p1
end note
@enduml


