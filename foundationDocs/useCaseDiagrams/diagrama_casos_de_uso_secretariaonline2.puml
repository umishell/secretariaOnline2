' =============================================================================
' SecretariaOnline2 — modelo de casos de uso (PlantUML)
' Tres diagramas no mesmo ficheiro (PlantUML nao aceita "newpage" fiavel neste
' tipo de diagrama de caso de uso com o motor atual — gera 3 PNG ao exportar).
'
' CLI: npx plantuml-cli -tpng diagrama_casos_de_uso_secretariaonline2.puml
' =============================================================================

@startuml diagrama_casos_de_uso_secretariaonline2_p1

title SecretariaOnline2 - casos de uso (visao por modulo)\nPagina 1 de 3 - atores no centro, modulos a esquerda e direita

skinparam defaultFontName Helvetica
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundcorner 8
skinparam actorStyle awesome
skinparam ArrowColor #334455
skinparam packageBorderColor #556677
skinparam nodesep 18
skinparam ranksep 28
left to right direction

legend bottom
  Linha continua = participacao primaria. | UC-FOR-03 so A5 (CAAF). | UC-PRE-02 = operacao no dia (QR/PIN).
  Paginas 2-3: ver ficheiro (S1-S5; include/extend).
end legend

package "Modulos (esquerda)\nportal, IAM, solicitacoes,\nformativas, estagio, TCC" as GLEFT #F8FAFC {
  package "Conteudo publico" as M_PUB {
    usecase "UC-PUB-01\nPagina institucional / erro" as UC_PUB01
  }
  package "Dashboards" as M_DASH {
    usecase "UC-DASH-01\nDashboard contextual (BFF)" as UC_DASH
  }
  package "Identidade e acesso" as M_IAM {
    usecase "UC-AUT-01\nAutenticar-se" as UC_A01
    usecase "UC-AUT-02\nRecuperar senha" as UC_A02
    usecase "UC-AUT-03\nRedefinir senha" as UC_A03
    usecase "UC-AUT-04\nCompletar primeiro acesso" as UC_A04
    usecase "UC-AUT-05\nPerfil e seguranca" as UC_A05
    usecase "UC-AUT-06\nPreferencias de notificacao" as UC_A06
  }
  package "Solicitacoes / workflow" as M_SOL {
    usecase "UC-SOL-01\nAbrir solicitacao (wizard)" as UC_S01
    usecase "UC-SOL-02\nAbrir solicitacao interna" as UC_S02
    usecase "UC-SOL-03\nAcompanhar solicitacao" as UC_S03
    usecase "UC-SOL-04\nDeliberar solicitacao" as UC_S04
    usecase "UC-SOL-05\nGerar protocolo PDF" as UC_S05
    usecase "UC-SOL-06\nTriar fila de solicitacoes" as UC_S06
    usecase "UC-SOL-07\nAutorizacao de imagem (lote)" as UC_S07
  }
  package "Formativas" as M_FOR {
    usecase "UC-FOR-01\nSubmeter formativa" as UC_F01
    usecase "UC-FOR-02\nAcompanhar formativa" as UC_F02
    usecase "UC-FOR-03\nRevisar formativa\n(so CAAF)" as UC_F03
    usecase "UC-FOR-04\nPainel comissao CAAF" as UC_F04
  }
  package "Estagio" as M_EST {
    usecase "UC-EST-01\nEstagio (aluno)" as UC_E01
    usecase "UC-EST-02\nOrientar / parecer estagio" as UC_E02
    usecase "UC-EST-03\nPainel comissao COE" as UC_E03
  }
  package "TCC" as M_TCC {
    usecase "UC-TCC-01\nTCC (aluno)" as UC_T01
    usecase "UC-TCC-02\nOrientar / examinar TCC" as UC_T02
  }
  M_PUB -[hidden]down- M_DASH
  M_DASH -[hidden]down- M_IAM
  M_IAM -[hidden]down- M_SOL
  M_SOL -[hidden]down- M_FOR
  M_FOR -[hidden]down- M_EST
  M_EST -[hidden]down- M_TCC
}

package "Atores\n(primarios + S6)" as MID #FFFEF5 {
  together {
    actor "A1\nVisitante" as A1
    actor "A2\nAluno" as A2
    actor "A3\nEgresso" as A3
    actor "A4\nProfessor" as A4
    actor "A5\nMembro CAAF" as A5
  }
  together {
    actor "A6\nMembro COE" as A6
    actor "A7\nSecretaria" as A7
    actor "A8\nCoordenador" as A8
    actor "A9\nAdministrador" as A9
    actor "S6\nVerificador\nexterno" as S6
  }
}

package "Modulos (direita)\npresenca, comunicacao,\ncadastro, egresso, atendimento,\ncertificados, administracao" as GRIGHT #F8FAFC {
  package "Presenca em eventos v4.1" as M_PRES {
    usecase "UC-PRE-01\nCRUD de eventos\n(event.manage)" as UC_P01
    usecase "UC-PRE-02\nOperar validacao no evento\n(QR/PIN, janelas)" as UC_P02
    usecase "UC-PRE-03\nConfirmar presenca (aluno)" as UC_P03
    usecase "UC-PRE-04\nEncerrar evento / regras" as UC_P04
  }
  package "Comunicacao" as M_COM {
    usecase "UC-COM-01\nHub de comunicacao" as UC_C01
    usecase "UC-COM-02\nComunicado de turma" as UC_C02
    usecase "UC-COM-03\nTemplates de comunicacao" as UC_C03
  }
  package "Cadastro academico" as M_ACAD {
    usecase "UC-CAD-01\nCRUD alunos" as UC_D01
    usecase "UC-CAD-02\nCRUD cursos" as UC_D02
    usecase "UC-CAD-03\nCRUD disciplinas" as UC_D03
    usecase "UC-CAD-04\nPeriodos e calendario" as UC_D04
    usecase "UC-CAD-05\nParametros do curso" as UC_D05
  }
  package "Egresso / diploma" as M_DIP {
    usecase "UC-EGR-01\nDashboard egresso" as UC_G01
    usecase "UC-EGR-02\nColacao / diploma" as UC_G02
    usecase "UC-EGR-03\nListar / exportar egressos" as UC_G03
  }
  package "Atendimento" as M_ATD {
    usecase "UC-ATD-01\nRegistrar atendimento" as UC_R01
    usecase "UC-ATD-02\nCiencia do atendimento" as UC_R02
  }
  package "Certificados / verificacao publica" as M_CERT {
    usecase "UC-CRT-01\nCertificados proprios" as UC_X01
    usecase "UC-CRT-02\nVerificar protocolo (publico)" as UC_X02
    usecase "UC-CRT-03\nVerificar certificado (publico)" as UC_X03
  }
  package "Administracao e operacao" as M_ADM {
    usecase "UC-ADM-01\nCRUD usuarios global" as UC_M01
    usecase "UC-ADM-02\nFGAC (perfis / authorities)" as UC_M02
    usecase "UC-ADM-03\nTipos de solicitacao" as UC_M03
    usecase "UC-ADM-04\nOutbox / jobs" as UC_M04
    usecase "UC-ADM-05\nAudit log" as UC_M05
    usecase "UC-ADM-06\nImportar planilhas" as UC_M06
    usecase "UC-ADM-07\nExportar relatorios" as UC_M07
    usecase "UC-ADM-08\nEstatisticas secretaria" as UC_M08
    usecase "UC-ADM-09\nRelatorios coordenacao" as UC_M09
    usecase "UC-ADM-10\nBusca global" as UC_M10
    usecase "UC-ADM-11\nSuporte / FAQ" as UC_M11
    usecase "UC-ADM-12\nTarefas internas" as UC_M12
  }
  M_PRES -[hidden]down- M_COM
  M_COM -[hidden]down- M_ACAD
  M_ACAD -[hidden]down- M_DIP
  M_DIP -[hidden]down- M_ATD
  M_ATD -[hidden]down- M_CERT
  M_CERT -[hidden]down- M_ADM
}

GLEFT -[hidden]right- MID
MID -[hidden]right- GRIGHT

A1 --> UC_PUB01
A1 --> UC_A01
A1 --> UC_A02
