@startuml diagrama_casos_de_uso_secretariaonline2_p2

title SecretariaOnline2 - sistemas externos (S1 a S5)\nPagina 2 de 3

skinparam packageStyle rectangle
left to right direction

actor "S1\nIAM" as S1
actor "S2\nNotificacoes Hub" as S2
actor "S3\nMotor workflow" as S3
actor "S4\nEmissor certificados" as S4
actor "S5\nObject storage" as S5

package "Colaboracao com sistemas externos" as Z {
  usecase "Grupo UC-AUT-01 a UC-AUT-06" as z1
  usecase "Grupo UC-SOL-01 a UC-SOL-07" as z2
  usecase "UC-CRT-01, UC-SOL-05,\nUC-FOR-02, UC-PRE-04" as z3
  usecase "Anexos / PDFs\n(SOL, FOR, EST, TCC)" as z4
}

z1 ..> S1 : tokens / sessao
z2 ..> S3 : workflow_json / transicoes
z2 ..> S2 : e-mail / push / in-app
z3 ..> S4 : hash / assinatura / PDF
z4 ..> S5 : blobs (S3 / MinIO)

note bottom of S2
  S2 tambem consome Outbox para entregas
  consistentes com o banco (ADR Outbox).
end note

@enduml


@startuml diagrama_casos_de_uso_secretariaonline2_p3

title SecretariaOnline2 - include e extend\nPagina 3 de 3 (casos_de_uso.md secao 4)

left to right direction

usecase "UC-AUT-01\nAutenticar-se" as UCLOGIN
usecase "UC-AUT-04\nCompletar primeiro acesso" as UCFIRST
usecase "UC-SOL-01\nAbrir solicitacao" as UCOPEN
usecase "Ext.: salvar rascunho\n(condicional)" as UCDRAFT
usecase "UC-SOL-04\nDeliberar solicitacao" as UCDEL
usecase "Ext.: deep-link JWT\n1-uso (?token=)" as UCDEEP
usecase "Inc.: validar capability +\nworkflow / motor S3" as UCAUTHZ

UCFIRST ..> UCLOGIN : (extend) mustChangePassword
UCDRAFT ..> UCOPEN : (extend) rascunho opcional
UCDEEP ..> UCDEL : (extend) deep-link JWT 1-uso
UCAUTHZ ..> UCDEL : (include) capability + workflow S3

note right of UCAUTHZ
  Include logico tambem presente em
  UC-PRE-03, UC-FOR-03, UC-EGR-02, etc.
  (tabela secao 4.1 em casos_de_uso.md).
end note

@enduml
